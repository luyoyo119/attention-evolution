---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Container from '../components/shared/Container.astro';
import ArticleCard from '../components/shared/ArticleCard.astro';
import { readingTime } from '../utils/readingTime';
import { getCollection } from 'astro:content';

const allCollections = ['decode', 'radar', 'deepread', 'evolution', 'workshop'] as const;
const articles = (await Promise.all(
  allCollections.map(async (c) => {
    const items = await getCollection(c);
    return items
      .filter(a => !a.data.draft)
      .map(a => ({
        title: a.data.title,
        series: a.data.series,
        seriesNumber: a.data.seriesNumber ?? 0,
        date: a.data.date,
        excerpt: a.data.excerpt,
        readingTime: a.data.readingTime ?? readingTime(a.body ?? ''),
        slug: `/${c}/${a.slug}/`,
      }));
  })
)).flat();

// Sort by date descending
const sorted = articles.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="全部文章" description="注意力机制全部文章存档">
  <Container size="wide">
    <div class="py-12">
      <h1 class="text-3xl font-extrabold mb-8" style="color: var(--text)">全部文章</h1>
      {sorted.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {sorted.map(a => (
            <ArticleCard
              title={a.title}
              series={a.series}
              seriesNumber={a.seriesNumber}
              date={a.date}
              excerpt={a.excerpt}
              readingTime={a.readingTime}
              slug={a.slug}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20 rounded-xl" style="background: var(--bg-card)">
          <p class="text-lg" style="color: var(--text-secondary)">还没有文章</p>
        </div>
      )}
    </div>
  </Container>
</BaseLayout>
