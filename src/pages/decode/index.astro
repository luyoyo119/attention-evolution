---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SeriesIndex from '../../components/series/SeriesIndex.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('decode');
const articles = items
  .filter(a => !a.data.draft)
  .map(a => ({
    title: a.data.title,
    series: a.data.series,
    seriesNumber: a.data.seriesNumber ?? 0,
    date: a.data.date,
    excerpt: a.data.excerpt,
    readingTime: a.data.readingTime,
    slug: `/decode/${a.slug}/`,
    body: a.body ?? '',
  }));
---

<BaseLayout title="注意力解码" description="拆播客、拆演讲、拆叙事 — 训练你看穿'他说了什么，没说什么'。每篇标配回避清单。">
  <SeriesIndex series="decode" articles={articles} />
</BaseLayout>
