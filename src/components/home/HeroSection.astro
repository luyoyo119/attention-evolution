---
import Container from '../shared/Container.astro';
---

<section
  class="relative flex items-center justify-center min-h-[85vh] overflow-hidden"
  style="background: linear-gradient(135deg, var(--gradient-hero-start), var(--gradient-hero-end))"
>
  <!-- Hex dot grid overlay -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle, var(--text) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- Glow orbs -->
  <div class="absolute top-[-20%] left-[-10%] w-[40vw] h-[40vw] rounded-full blur-[120px] opacity-10" style="background: var(--c-decode)"></div>
  <div class="absolute bottom-[-20%] right-[-10%] w-[40vw] h-[40vw] rounded-full blur-[120px] opacity-10" style="background: var(--c-radar)"></div>

  <Container>
    <div class="text-center py-20 relative">
      <p class="text-sm tracking-[3px] mb-6 uppercase" style="color: var(--text-tertiary)">Attention Evolution</p>
      <h1 class="text-[42px] sm:text-[52px] font-extrabold mb-5 tracking-tight leading-none" style="color: var(--text)">
        注意力进化论
      </h1>
      <p class="text-xl sm:text-2xl mb-10 font-medium" style="color: var(--text-secondary)">
        看什么、不看什么，决定你理解世界的深度
      </p>
      <div class="flex items-center justify-center gap-4">
        <a
          href="#pillars"
          class="inline-flex items-center px-6 py-3 rounded-full text-sm font-medium border transition-all hover:opacity-80"
          style="color: var(--text); border-color: var(--border-strong)"
        >
          开始阅读
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a
          href="/about/"
          class="inline-flex items-center px-6 py-3 rounded-full text-sm font-medium transition-all hover:opacity-80"
          style="color: var(--text-secondary);"
        >
          关于我 →
        </a>
      </div>
    </div>
  </Container>
</section>
