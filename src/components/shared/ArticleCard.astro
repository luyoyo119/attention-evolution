---
import SeriesBadge from './SeriesBadge.astro';
import { formatDate } from '../../utils/dateFormat';

export interface Props {
  title: string;
  series: string;
  seriesNumber: number;
  date: Date;
  excerpt: string;
  readingTime: number;
  slug: string;
}

const { title, series, seriesNumber, date, excerpt, readingTime, slug } = Astro.props;
---

<a
  href={slug}
  class="group block p-5 rounded-xl border transition-all"
  style={{
    borderColor: 'var(--border)',
    backgroundColor: 'var(--bg-card)',
  }}
>
  <div class="flex items-center gap-2 mb-3">
    <SeriesBadge series={series} />
    <span class="text-xs" style="color: var(--text-tertiary)">#{seriesNumber}</span>
  </div>
  <h3 class="font-semibold mb-2 leading-snug group-hover:opacity-70 transition-opacity" style="color: var(--text)">
    {title}
  </h3>
  <p class="text-sm mb-3 line-clamp-2" style="color: var(--text-secondary)">
    {excerpt}
  </p>
  <div class="flex items-center gap-3 text-xs" style="color: var(--text-tertiary)">
    <time datetime={String(date)}>{formatDate(date)}</time>
    <span>·</span>
    <span>{readingTime} 分钟</span>
  </div>
</a>
