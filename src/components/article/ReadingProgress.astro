<div id="reading-progress" class="fixed top-0 left-0 h-[3px] z-[60] transition-colors" style="background: var(--c-decode); width: 0%"></div>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      const scrollH = h.scrollHeight - h.clientHeight;
      const pct = scrollH > 0 ? (h.scrollTop / scrollH) * 100 : 0;
      bar.style.width = `${Math.min(100, Math.max(0, pct))}%`;
    }, { passive: true });
  }
</script>
