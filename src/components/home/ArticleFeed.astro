---
import ArticleCard from '../shared/ArticleCard.astro';
import { readingTime } from '../../utils/readingTime';

export interface Props {
  articles: Array<{
    title: string;
    series: string;
    seriesNumber: number;
    date: Date;
    excerpt: string;
    readingTime?: number;
    slug: string;
    body?: string;
  }>;
}

const { articles } = Astro.props;
---

<section class="mt-12">
  <h2 class="text-lg font-semibold tracking-tight mb-6" style="color: var(--text)">最新文章</h2>
  <div class="flex flex-col space-y-6">
    {articles.map(a => (
      <ArticleCard
        title={a.title}
        series={a.series}
        seriesNumber={a.seriesNumber}
        date={a.date}
        excerpt={a.excerpt}
        readingTime={a.readingTime ?? readingTime(a.body ?? '')}
        slug={a.slug}
      />
    ))}
  </div>
  <div class="mt-6">
    <a href="/archive/" class="text-sm transition-opacity hover:opacity-60" style="color: var(--text-secondary)">
      查看全部 →
    </a>
  </div>
</section>
