---
import SeriesBadge from './SeriesBadge.astro';
import { formatDate } from '../../utils/dateFormat';

export interface Props {
  title: string;
  series: string;
  seriesNumber: number;
  date: Date;
  excerpt: string;
  readingTime: number;
  slug: string;
}

const { title, series, seriesNumber, date, excerpt, readingTime, slug } = Astro.props;
---

<div class="w-full flex flex-col sm:flex-row sm:space-x-2">
  <!-- Date column -->
  <span class="text-sm text-neutral-500 dark:text-neutral-500 tabular-nums w-[110px] shrink-0 whitespace-nowrap mb-0.5 sm:mb-0">
    {formatDate(date)}
  </span>
  <!-- Content column -->
  <div class="flex flex-1 flex-col gap-1">
    <a
      href={slug}
      class="text-neutral-900 dark:text-neutral-100 tracking-tight hover:text-blue-500 dark:hover:text-blue-400 transition-colors"
    >
      {title}
    </a>
    <div class="flex items-center gap-2 flex-wrap">
      <SeriesBadge series={series} />
      <span class="text-xs text-neutral-400 dark:text-neutral-600">{readingTime} 分钟</span>
    </div>
    <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">
      {excerpt}
    </p>
  </div>
</div>
