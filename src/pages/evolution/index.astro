---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SeriesIndex from '../../components/series/SeriesIndex.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('evolution');
const articles = items
  .filter(a => !a.data.draft)
  .map(a => ({
    title: a.data.title,
    series: a.data.series,
    seriesNumber: a.data.seriesNumber ?? 0,
    date: a.data.date,
    excerpt: a.data.excerpt,
    readingTime: a.data.readingTime,
    slug: `/evolution/${a.slug}/`,
    body: a.body ?? '',
  }));
---

<BaseLayout title="注意力的进化" description="AI 机制的科普系列。稀疏注意力、记忆进化、人类遗忘危机 — 从技术出发，回到人的处境。">
  <SeriesIndex series="evolution" articles={articles} />
</BaseLayout>
