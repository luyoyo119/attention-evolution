---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Container from '../components/shared/Container.astro';

// Career data
const career = [
  {
    period: '2024 ~',
    role: '采购总监',
    org: '国家级科研机构',
    highlights: [
      '搭建采购管理体系，覆盖设备、服务、试剂耗材等多品类',
      '建立供应商分类分级管理体系',
    ],
  },
  {
    period: '2021 ~ 2024',
    role: '供应链中心 专业副总监',
    org: '大型医疗健康集团',
    highlights: [
      '负责40+下属机构集采策略，组织多品类集采招标，实现显著降本',
      '搭建集团供应商管理体系与战略供应商资源池',
    ],
  },
  {
    period: '2018 ~ 2021',
    role: '医疗事业部 设备条线负责人',
    org: '大型产业投资集团',
    highlights: [
      '同期管理4家三级综合医院筹开采购，统筹多品类采购',
      '制定9大专科设备配置标准与模块化采购方案',
    ],
  },
  {
    period: '2011 ~ 2018',
    role: '采购及项目主管',
    org: '大型三甲医院',
    highlights: [
      '全院设备采购全生命周期管理',
      '参与起草多项国家级采购标准及制度',
    ],
  },
];

const categories = [
  { emoji: '🧮', name: '算力与IT基础设施', desc: 'GPU集群及配套设备、高性能计算集群、大容量并行存储、高速网络设备' },
  { emoji: '💻', name: '软件与技术平台', desc: '医疗软件、科研软件、网络安全方案等' },
  { emoji: '🔬', name: '医疗/科研物资', desc: '大型医疗影像设备、科研仪器、科研试剂耗材等' },
  { emoji: '📋', name: '专业服务', desc: '科研服务、法律咨询、审计咨询、猎头服务等' },
  { emoji: '🏗️', name: '工程与后勤物资', desc: '医疗专项工程、科研设施、后勤物资等' },
  { emoji: '🪑', name: '行政与办公', desc: '办公设备、行政物资、办公耗材等' },
];

const articles = [
  { title: 'Anthropic赚疯、DeepSeek开源、智谱转型——模型公司到底怎么赚钱？（上/下）', href: '/decode/decode-4-model-companies-1/', series: 'decode' },
  { title: '拆解黄仁勋2026年台北GTC演讲', href: '/decode/decode-1-huang-renxun-speech/', series: 'decode' },
  { title: '7000亿美元砸向AI，然后呢？', href: '/decode/decode-2-benedict-evans/', series: 'decode' },
  { title: 'Fable 5 屠榜了，但最值得关注的不只是模型本身', href: '/radar/radar-1-fable5-harness/', series: 'radar' },
  { title: 'AI 为何开始"选择性失明"——稀疏注意力的诞生', href: '/evolution/evolution-2-sparse-attention/', series: 'evolution' },
  { title: '注意力的镜像：AI 的记忆进化 vs 人类的遗忘危机', href: '/evolution/evolution-3-attention-mirror/', series: 'evolution' },
  { title: '在用 AI 处理工作文件之前，先给它打个码', href: '/workshop/workshop-1-file-masking/', series: 'workshop' },
  { title: '2026年毕业季：当优绩主义的地图失效，我们该如何爱自己？', href: '/decode/decode-7-graduation-2026/', series: 'decode' },
];

const seriesColors: Record<string, string> = {
  decode: '#667eea',
  radar: '#4285f4',
  deepread: '#10ac84',
  evolution: '#6c5ce7',
  workshop: '#e8a820',
};
---

<BaseLayout
  title="关于 yoyo — 采购专家 × AI 学习者"
  description="15年采购与供应链管理经验，AI/大模型/投资持续学习者，公众号「注意力进化论」主理人。"
>
  <Container size="prose">
    <div class="py-10 space-y-14">

      <!-- ========== HERO ========== -->
      <section class="space-y-5">
        <h1 class="text-3xl font-extrabold tracking-tight" style="color: var(--text)">yoyo</h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-secondary)">
          采购专家<span style="color: var(--text-tertiary)"> × </span>AI 深度学习者<span style="color: var(--text-tertiary)"> × </span>内容创作者
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary); max-width: 560px;">
          15年采购与供应链管理经验，历经单体医院→医疗集团→国家级科研机构。
          从执行采购到体系搭建，采购品类涉及高性能智算集群、科研设备、医疗设备、软件、专业服务等多大类。
          工作之外，持续学习AI/大模型/投资，运营公众号「注意力进化论」。
        </p>
        <div class="flex flex-wrap gap-3 text-xs pt-1">
          <span class="px-3 py-1.5 rounded-full" style="background: var(--bg-card); color: var(--text-secondary);">📍 北京</span>
          <span class="px-3 py-1.5 rounded-full" style="background: var(--bg-card); color: var(--text-secondary);">📧 finally119@163.com</span>
          <a href="https://attention-evolution.com" class="px-3 py-1.5 rounded-full transition-opacity hover:opacity-70" style="background: var(--bg-card); color: var(--c-decode);">🔗 attention-evolution.com</a>
        </div>
      </section>

      <!-- ========== PROCUREMENT ========== -->
      <section class="space-y-5">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">🛒</span>
          <h2 class="text-xl font-bold" style="color: var(--text)">专业领域</h2>
        </div>

        <!-- Category grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {categories.map(cat => (
            <div class="p-4 rounded-xl transition-colors" style="background: var(--bg-card); border: 1px solid var(--border)">
              <div class="text-sm font-semibold mb-1" style="color: var(--text)">{cat.emoji} {cat.name}</div>
              <div class="text-xs leading-relaxed" style="color: var(--text-secondary)">{cat.desc}</div>
            </div>
          ))}
        </div>

        <!-- Methodology -->
        <div class="p-5 rounded-xl space-y-3" style="background: var(--bg-card); border: 1px solid var(--border)">
          <div class="text-sm font-semibold" style="color: var(--text)">🔧 核心方法论</div>
          <div class="flex flex-wrap gap-2">
            {['业务需求翻译为采购方案','集采策略与规模议价','合同谈判及法务风控'].map(skill => (
              <span class="px-2.5 py-1 text-xs rounded-md" style="background: var(--bg-tertiary); color: var(--text-secondary)">{skill}</span>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== CAREER ========== -->
      <section class="space-y-5">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">📈</span>
          <h2 class="text-xl font-bold" style="color: var(--text)">职业路径</h2>
        </div>
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-800"></div>
          <div class="space-y-8">
            {career.map((job, i) => (
              <div class="relative flex items-start ml-4">
                <!-- Dot -->
                <div class="absolute -left-4 mt-1.5">
                  <div class="w-3 h-3 rounded-full bg-blue-500 dark:bg-blue-400 ring-4 ring-white dark:ring-black"></div>
                </div>
                <!-- Content -->
                <div class="ml-6">
                  <span class="block text-sm font-semibold text-blue-500 dark:text-blue-400 mb-1">{job.period}</span>
                  <span class="block text-gray-700 dark:text-gray-300 text-sm">{job.role} — {job.org}</span>
                  <ul class="mt-2 space-y-1">
                    {job.highlights.map(h => (
                      <li class="text-xs text-gray-500 dark:text-gray-400">{h}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== CONTENT ========== -->
      <section class="space-y-5">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">✍️</span>
          <h2 class="text-xl font-bold" style="color: var(--text)">内容</h2>
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary); max-width: 560px;">
          运营微信公众号「<strong style="color: var(--text)">注意力进化论</strong>」，已发布多篇AI行业深度分析。
          核心信念：<strong style="color: var(--text)">注意力是最稀缺的资源</strong>，决定看什么、不看什么，决定你理解世界的深度。
        </p>

        <!-- Featured articles -->
        <div class="space-y-2">
          {articles.map(a => (
            <a
              href={a.href}
              class="flex items-center gap-3 p-3 rounded-lg transition-colors hover:opacity-80"
              style="background: var(--bg-card); border: 1px solid var(--border)"
            >
              <span class="text-xs font-medium px-2 py-0.5 rounded" style={`background: ${seriesColors[a.series]}22; color: ${seriesColors[a.series]}`}>
                {a.series === 'decode' ? '🌳 解码' : a.series === 'radar' ? '📡 雷达' : a.series === 'evolution' ? '🧬 进化' : a.series === 'workshop' ? '🔧 工坊' : '📖 深读'}
              </span>
              <span class="text-sm font-medium flex-1" style="color: var(--text)">{a.title}</span>
              <span class="text-xs" style="color: var(--text-tertiary)">→</span>
            </a>
          ))}
        </div>

        <div class="flex flex-wrap gap-3 text-xs pt-1">
          {[
            { label: '🌳 注意力解码', desc: '拆播客/演讲/事件，每篇有回避清单' },
            { label: '📡 注意力雷达', desc: '行业全景对比，碎片拼成地图' },
            { label: '📖 注意力深读', desc: '拆书/论文，15分钟拿80%精华' },
          ].map(col => (
            <span class="px-3 py-1.5 rounded-full" style="background: var(--bg-card); color: var(--text-secondary);">
              {col.label}<span class="ml-1" style="color: var(--text-tertiary)">{col.desc}</span>
            </span>
          ))}
        </div>
      </section>

      <!-- ========== CONTACT ========== -->
      <section class="space-y-5">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">📬</span>
          <h2 class="text-xl font-bold" style="color: var(--text)">联系</h2>
        </div>
        <div class="flex flex-wrap gap-3 text-sm">
          <a href="mailto:finally119@163.com" class="px-4 py-2.5 rounded-xl transition-opacity hover:opacity-70 inline-flex items-center gap-2" style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text)">
            <span>📧</span> 邮件联系
          </a>
          <span class="px-4 py-2.5 rounded-xl inline-flex items-center gap-2" style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary)">
            <span>💬</span> 微信公众号：注意力进化论
          </span>
        </div>
      </section>

      <!-- Spacer -->
      <div class="h-4"></div>

    </div>
  </Container>
</BaseLayout>
