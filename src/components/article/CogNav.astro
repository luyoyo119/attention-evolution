---
export interface RelatedLink {
  title: string;
  slug: string;
}

export interface Props {
  summary: string;
  related: RelatedLink[];
  seriesColor?: string;
}

const { summary, related, seriesColor } = Astro.props;
const color = seriesColor ?? 'var(--c-decode)';
---

<div
  class="my-12 p-6 rounded-xl"
  style={{
    borderLeft: `3px solid ${color}`,
    backgroundColor: 'var(--bg-card)',
  }}
>
  <h3 class="flex items-center gap-2 font-bold mb-3 text-[17px]" style="color: var(--text)">
    <span>🧭</span> 认知导航
  </h3>
  <p class="text-[15px] mb-5" style="color: var(--text-secondary); line-height: 1.7;">
    {summary}
  </p>
  {related.length > 0 && (
    <div class="space-y-2">
      <p class="text-xs font-medium mb-2" style="color: var(--text-tertiary)">继续阅读：</p>
      {related.map(link => (
        <a
          href={link.slug}
          class="block text-[15px] py-1.5 transition-opacity hover:opacity-70"
          style={{ color }}
        >
          → {link.title}
        </a>
      ))}
    </div>
  )}
</div>
