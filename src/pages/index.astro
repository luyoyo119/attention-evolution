---
import BaseLayout from '../components/layout/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';

import ArticleFeed from '../components/home/ArticleFeed.astro';

import { getCollection } from 'astro:content';

// Gather all published articles, sorted by date
const allCollections = ['decode', 'radar', 'deepread', 'evolution', 'workshop', 'standalone'] as const;
const articles = (await Promise.all(
  allCollections.map(async (c) => {
    const items = await getCollection(c);
    return items
      .filter(a => !a.data.draft)
      .map(a => ({
        title: a.data.title,
        series: a.data.series,
        seriesNumber: a.data.seriesNumber ?? 0,
        date: a.data.date,
        excerpt: a.data.excerpt,
        readingTime: a.data.readingTime,
        slug: `/${c}/${a.slug}/`,
        body: a.body ?? '',
      }));
  })
)).flat();

// Sort by date descending, take top 6
const latest = articles
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 6);
---

<BaseLayout
  title="注意力进化论 — 决定看什么、不看什么"
  description="注意力是你最稀缺的资源。决定看什么、不看什么，决定你理解世界的深度。一个普通人的 AI 认知成长记录。"
>
  <HeroSection />
  <div id="articles">
  {latest.length > 0 && <ArticleFeed articles={latest} />}
  </div>
  <section class="mt-12">
    <a href="/about/" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-neutral-200 transition-colors">
      了解更多关于我的专业背景及内容 →
    </a>
  </section>
</BaseLayout>
