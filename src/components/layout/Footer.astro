---
import Container from '../shared/Container.astro';
import { SERIES } from '../../config';

const navSeries = ['decode', 'radar', 'deepread', 'evolution', 'workshop'];
---

<footer class="border-t py-12 mt-16" style="border-color: var(--border); background: var(--bg-secondary)">
  <Container size="wide">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <!-- Series -->
      <div>
        <h4 class="font-semibold mb-3 text-sm" style="color: var(--text)">系列栏目</h4>
        <div class="flex flex-col gap-2">
          {navSeries.map(slug => (
            <a
              href={`/${slug}/`}
              class="text-sm transition-opacity hover:opacity-60"
              style="color: var(--text-secondary)"
            >
              {SERIES[slug].emoji} {SERIES[slug].label}
            </a>
          ))}
        </div>
      </div>
      <!-- Other -->
      <div>
        <h4 class="font-semibold mb-3 text-sm" style="color: var(--text)">更多</h4>
        <div class="flex flex-col gap-2">
          <a href="/podcast/" class="text-sm transition-opacity hover:opacity-60" style="color: var(--text-secondary)">🎙️ 透透气</a>
          <a href="/about/" class="text-sm transition-opacity hover:opacity-60" style="color: var(--text-secondary)">👤 关于 Alex</a>
          <a href="/archive/" class="text-sm transition-opacity hover:opacity-60" style="color: var(--text-secondary)">📋 全部文章</a>
        </div>
      </div>
      <!-- Subscribe -->
      <div>
        <h4 class="font-semibold mb-3 text-sm" style="color: var(--text)">订阅</h4>
        <div class="flex flex-col gap-2">
          <a href="/rss.xml" class="text-sm transition-opacity hover:opacity-60" style="color: var(--text-secondary)">📡 RSS 订阅</a>
          <span class="text-sm" style="color: var(--text-tertiary)">关注公众号「注意力机制」</span>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 text-center border-t" style="border-color: var(--border)">
      <p class="text-xs" style="color: var(--text-tertiary)">
        注意力机制 © 2026 · Built with Astro · Deployed on Netlify
      </p>
    </div>
  </Container>
</footer>
