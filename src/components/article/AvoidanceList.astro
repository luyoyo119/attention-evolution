---
import { getSeries } from '../../utils/series';

export interface Props {
  items: string[];
  seriesColor?: string;
}

const { items, seriesColor } = Astro.props;
const color = seriesColor ?? 'var(--c-decode)';
---

<div
  class="my-10 p-6 rounded-xl border"
  style={{
    borderColor: color + '44',
    backgroundColor: color + '12',
  }}
>
  <h3 class="flex items-center gap-2 font-bold mb-4 text-[17px]" style={{ color }}>
    <span class="text-lg">🚫</span> 回避清单
  </h3>
  <p class="text-sm mb-4" style="color: 'var(--text-secondary)'">
    以下是作者选择性省略、回避，或未充分讨论的问题：
  </p>
  <ul class="space-y-2">
    {items.map(item => (
      <li class="flex gap-3 text-[15px]" style="color: 'var(--text-secondary)'">
        <span class="mt-[2px] flex-shrink-0">•</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
